generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  companies Company[]
}

model Company {
  id            Int      @id @default(autoincrement())
  companyName   String
  gstNumber     String?
  address       String?
  state         String?
  financialYear String?
  createdAt     DateTime @default(now())

  userId Int
 user       User @relation(fields: [userId], references: [id])
ledgers    Ledger[]
stockItems StockItem[]
salesVouchers SalesVoucher[]
purchaseVouchers PurchaseVoucher[]
}

model Ledger {
  id          Int      @id @default(autoincrement())
  name        String
  type        String
  openingBal  Float    @default(0)

  companyId   Int
  company     Company  @relation(fields: [companyId], references: [id])

  createdAt   DateTime @default(now())
}

model StockItem {
  id           Int      @id @default(autoincrement())
  itemName     String
  unit         String
  rate         Float
  openingStock Float
  stockValue   Float

  companyId    Int
  company      Company @relation(fields: [companyId], references: [id])

  createdAt    DateTime @default(now())
}

model SalesVoucher {
  id          Int      @id @default(autoincrement())
  invoiceNo   String   @unique

  customerName String

  itemName    String
  quantity    Float
  rate        Float
  amount      Float

  companyId   Int
  company     Company @relation(fields: [companyId], references: [id])

  createdAt   DateTime @default(now())
}


model PurchaseVoucher {
  id           Int      @id @default(autoincrement())
  invoiceNo    String   @unique

  supplierName String

  itemName     String
  quantity     Float
  rate         Float
  amount       Float

  companyId    Int
  company      Company @relation(fields: [companyId], references: [id])

  createdAt    DateTime @default(now())
}